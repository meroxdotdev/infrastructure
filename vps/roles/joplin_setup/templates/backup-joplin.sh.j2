#!/bin/bash
# Daily Joplin PostgreSQL dump. Deployed by ansible (joplin_setup role).
set -euo pipefail

BACKUP_DIR="/srv/backups/joplin"
mkdir -p "$BACKUP_DIR"
chmod 700 "$BACKUP_DIR"

docker exec -e PGPASSWORD='{{ joplin_db_password }}' joplin-db \
  pg_dump -U {{ joplin_db_user }} {{ joplin_db_name }} \
  | gzip > "$BACKUP_DIR/joplin_$(date +%F_%H%M).sql.gz"

find "$BACKUP_DIR" -name 'joplin_*.sql.gz' -mtime +{{ joplin_backup_retention_days }} -delete
