#!/bin/bash
# DR: restore the small service state captured by backup-vps-extras.sh.
# For each target, untars the newest /srv/backups/<name>/<name>_*.tar.gz over
# its live path, stopping/starting the affected container around the untar
# (same stop/restore/start pattern as restore-db.sh). Non-interactive — DR
# use only, OVERWRITES current state. Run after restore-pull-from-r730xd.sh and
# after the app stack / Guacamole / Traefik / Pi-hole containers exist.
# Deployed by ansible (vps_backup role).
set -euo pipefail
trap 'echo "✗ restore-extras failed at line $LINENO: $BASH_COMMAND" >&2' ERR

BACKUP_ROOT="{{ vps_backup_root }}"

restore_tar() {
  local name="$1" dest="$2" container="${3:-}"
  local archive
  archive=$(ls -1t "$BACKUP_ROOT/$name/${name}_"*.tar.gz 2>/dev/null | head -1) || true
  if [ -z "$archive" ]; then
    echo "✗ $name: no backup found in $BACKUP_ROOT/$name/, skipping"
    return 0
  fi

  echo "→ $name: restoring $archive -> $dest"
  [ -n "$container" ] && docker stop "$container" >/dev/null
  mkdir -p "$dest"
  tar -xzf "$archive" -C "$dest"
  if [ -n "$container" ]; then
    docker start "$container" >/dev/null
    echo "  ✓ $container restarted"
  fi
}

restore_tar guacamole /var/lib/docker/volumes/guacamole_guacamole_config/_data guacamole
restore_tar traefik /srv/docker/oracle-cloud/traefik traefik
restore_tar pihole /srv/docker/oracle-cloud/etc-pihole pihole
restore_tar pihole-dnsmasq /srv/docker/oracle-cloud/etc-dnsmasq.d pihole

# Repoint *.cloud.merox.dev local DNS (Pi-hole) from the tailscale IP baked
# into the backup (this VPS's tailscale_expected_ip at backup time) to this
# VPS's CURRENT tailscale IP. Every DR rebuild gets a new tailnet IP, but the
# restored Pi-hole config still has the old one hardcoded - without this fix,
# every *.cloud.merox.dev hostname resolves to a dead tailnet peer.
OLD_TS_IP="{{ tailscale_expected_ip }}"
NEW_TS_IP=$(tailscale ip -4 2>/dev/null || true)
if [ -n "$NEW_TS_IP" ] && [ "$NEW_TS_IP" != "$OLD_TS_IP" ]; then
  echo "→ pihole-dns: repointing *.cloud.merox.dev from $OLD_TS_IP to $NEW_TS_IP"
  sed -i "s/$OLD_TS_IP/$NEW_TS_IP/g" \
    /srv/docker/oracle-cloud/etc-dnsmasq.d/02-custom.conf \
    /srv/docker/oracle-cloud/etc-pihole/pihole.toml \
    /srv/docker/oracle-cloud/etc-pihole/hosts/custom.list
  docker restart pihole >/dev/null
  echo "  ✓ pihole restarted - remember to update tailscale_expected_ip to $NEW_TS_IP in vars.yml for the next DR"
fi

restore_tar homepage /srv/docker/oracle-cloud/config homepage
restore_tar portainer /var/lib/docker/volumes/oracle-cloud_portainer_data/_data portainer

echo "$(date -Is) restore-extras completed"
