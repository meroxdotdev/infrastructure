#!/bin/bash
# DR: pull R730xd's copy of VPS service backups back onto a fresh VPS, before
# restore-db.sh or restore-extras.sh run (both read from /srv/backups, which
# is empty on a fresh VPS).
#
# Mirror of backup-push-r730xd.sh, opposite direction: plain SSH rsync pull
# straight from R730xd - no daemon indirection, R730xd is plain Debian.
# Deployed by ansible (vps_backup role).
set -euo pipefail

R730XD_USER="{{ vps_backup_r730xd_user }}"
R730XD_HOST="{{ vps_backup_r730xd_host }}"
SSH_KEY="{{ vps_backup_r730xd_ssh_key }}"
SSH_OPTS="ssh -i $SSH_KEY -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

mkdir -p "{{ vps_backup_root }}"

rsync -a -e "$SSH_OPTS" "$R730XD_USER@$R730XD_HOST:/srv-backups/" "{{ vps_backup_root }}/"

echo "$(date -Is) restore pull from R730xd completed"
