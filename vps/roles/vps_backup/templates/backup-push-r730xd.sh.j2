#!/bin/bash
# Off-site push of VPS service backups (Authentik/Joplin/Guacamole/Traefik/
# Pi-hole/Homepage/Portainer) to R730xd (the always-on backup hub). From
# there, R730xd's own weekly push relays a copy to Synology cold storage,
# and Synology's HyperBackup relays onward to this same Oracle VPS - see
# proxmox/r730xd/README.md for the full loop.
#
# Deliberately does NOT touch this VPS's own local Garage instance - that's
# a temporary rollback safety net from the pre-2026-07-21 Longhorn cutover,
# not the live backup target anymore (that's R730xd's own Garage LXC, already
# covered by the existing longhorn-garage category on R730xd). Relaying it
# through R730xd -> Synology -> Oracle would just ship this VPS's own
# soon-to-be-decommissioned data back to itself.
#
# Plain SSH rsync push - no rsyncd daemon indirection needed here (that was
# only required for Synology's patched rsync refusing server-mode over SSH;
# R730xd is plain Debian). The SSH key is restricted server-side via rrsync +
# from= to only touch {{ vps_backup_r730xd_base }} - not ansible-managed,
# pve isn't in this inventory (see proxmox/r730xd/README.md for the exact
# authorized_keys line).
# Deployed by ansible (vps_backup role).
set -euo pipefail

R730XD_USER="{{ vps_backup_r730xd_user }}"
R730XD_HOST="{{ vps_backup_r730xd_host }}"
SSH_KEY="{{ vps_backup_r730xd_ssh_key }}"
SSH_OPTS="ssh -i $SSH_KEY -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

# rrsync on the pve side restricts this key to {{ vps_backup_r730xd_base }}
# as its root, so the remote path below is relative to that, not absolute.
rsync -a --delete -e "$SSH_OPTS" "{{ vps_backup_root }}/" "$R730XD_USER@$R730XD_HOST:/srv-backups/"

echo "$(date -Is) backup push to R730xd completed"
