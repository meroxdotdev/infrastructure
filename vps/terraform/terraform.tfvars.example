# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

hcloud_token        = "your-hetzner-api-token-here"
ssh_public_key_path = "~/.ssh/cloudlab_dr_test.pub"
server_name         = "cloudlab-vps"
server_type         = "cx33"     # 4vCPU x86, 8GB RAM — proven to work for DR (cax21/ARM untested)
server_location     = "nbg1"     # Nuremberg — change to hel1 for Helsinki
allowed_ips         = ["YOUR_HOME_IP/32"]   # Replace with your actual home IP
