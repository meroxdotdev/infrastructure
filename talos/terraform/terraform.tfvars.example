# Copy to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored

proxmox_url          = "https://10.57.57.254:8006"
proxmox_token_id     = "root@pam!terraform"   # create at: Proxmox → Datacenter → API Tokens
proxmox_token_secret = "your-token-secret-here"

# Optional overrides (defaults should work for most cases):
# proxmox_nodes  = ["px-0", "px-1", "px-2"]
# vmid_start     = 810
# vm_cores       = 4
# vm_memory_mb   = 8192
# vm_disk_gb     = 50
# node_ips       = ["10.57.57.90", "10.57.57.92", "10.57.57.94"]
# node_vip       = "10.57.57.98"
# iso_storage    = "local-data"    # must support 'iso' content on the node hosting the download
# disk_storage   = "cluster-storage"

# KNOWN WORKING (discovered during DR test 2026-06-04):
# - cluster-storage is enabled only on px-0; px-1/px-2 use 'storage' instead
# - local-data supports iso+images on all nodes but is node-local (not shared)
# - If distributing VMs across nodes, iso must be available on each node separately
# - Simplest DR approach: run all VMs on one node with local-data:
#     proxmox_nodes = ["px-0", "px-0", "px-0"]
#     disk_storage  = "local-data"
