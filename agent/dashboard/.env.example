# Dashboard secrets — copy to /srv/dashboard/.env and fill in values
# This file is safe to commit (no real values). /srv/dashboard/.env is gitignored.

# Telegram bot credentials (from BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_user_id_here

# Garage S3 admin token (from: docker exec garage /garage token list)
GARAGE_TOKEN=your_garage_admin_token_here
# Garage longhorn bucket ID (from: docker exec garage /garage bucket info longhorn)
GARAGE_BUCKET_ID=your_longhorn_bucket_id_here

# iCloud CalDAV credentials (use an app-specific password, not your Apple ID password)
APPLE_ID=your@icloud.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
