# OpenClaw environment variables
# Copy to ~/.openclaw/.env and fill in real values
# This file is gitignored — never commit real tokens

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAAA...

# Your Telegram user/chat ID — numeric (find via: openclaw logs --follow after sending a message)
TELEGRAM_CHAT_ID=123456789

# Garage S3 API token — from your Garage instance (garage key create)
GARAGE_TOKEN=your-garage-api-token-here

# Garage S3 bucket ID — from: garage bucket info <bucket-name>
GARAGE_BUCKET_ID=your-bucket-id-here
