#!/bin/bash
# Fixes openclaw file ownership after root operations (e.g. Claude Code sessions).
# Runs automatically: root crontab */5 * * * *, and systemd ExecStartPost.
# Safe to run any time.

OPENCLAW_USER="openclaw"

chown -R "${OPENCLAW_USER}:${OPENCLAW_USER}" /home/openclaw/.openclaw/ 2>/dev/null
chown -R "${OPENCLAW_USER}:${OPENCLAW_USER}" /srv/dashboard/ 2>/dev/null
# Update scripts stay root-owned — agents should not be able to modify them
chown root:root /srv/dashboard/update-infra.sh \
                /srv/dashboard/update-backup.sh \
                /srv/dashboard/update-news.sh 2>/dev/null
chown -R "${OPENCLAW_USER}:${OPENCLAW_USER}" /srv/merox/src/content/blog/ 2>/dev/null
